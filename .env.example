# ─── STARCADE — Environment Variables Template ─────────────────────────────────
# Copy this file to .env and fill in your deployed contract addresses.

VITE_NETWORK=sepolia   # or: mainnet

VITE_BASE_SEPOLIA_RPC=https://sepolia.base.org
VITE_BASE_SEPOLIA_EXPLORER=https://sepolia.basescan.org
VITE_CONTRACT_SEPOLIA=0xYOUR_SEPOLIA_CONTRACT_ADDRESS

VITE_BASE_MAINNET_RPC=https://mainnet.base.org
VITE_BASE_MAINNET_EXPLORER=https://basescan.org
VITE_CONTRACT_MAINNET=0xYOUR_MAINNET_CONTRACT_ADDRESS
